    "sections": [
      {
        "title": "Overview",
        "content": "Account access issues are among the most common IT support requests. They may involve forgotten passwords, locked accounts, authentication failures, password expiration, or multi-factor authentication (MFA) problems."
      },
      {
        "title": "Common Issues",
        "content": [
          "Forgotten password",
          "Account locked",
          "Incorrect username or password",
          "Password expired",
          "Login loop",
          "MFA code not received",
          "OTP expired",
          "Account disabled"
        ]
      },
      {
        "title": "Symptoms",
        "content": [
          "Unable to log in",
          "Invalid credentials",
          "Account locked",
          "Authentication failed",
          "MFA timeout",
          "Login page refreshes continuously"
        ]
      },
      {
        "title": "Possible Causes",
        "content": [
          "Incorrect password",
          "Password expiration",
          "Too many failed login attempts",
          "Disabled account",
          "Network issues",
          "Identity provider unavailable",
          "MFA device not synchronized"
        ]
      },
      {
        "title": "Troubleshooting",
        "content": [
          "Verify your username.",
          "Reset your password.",
          "Clear browser cache and cookies.",
          "Check your internet connection.",
          "Verify your MFA device.",
          "Wait a few minutes if your account has been temporarily locked.",
          "Contact the IT Administrator if the issue persists."
        ]
      },
      {
        "title": "Best Practices",
        "content": [
          "Use a strong and unique password.",
          "Never share your password.",
          "Enable multi-factor authentication (MFA).",
          "Keep your recovery information up to date."
        ]
      },
      {
        "title": "FAQ",
        "content": [
          {
            "question": "I forgot my password.",
            "answer": "Use the password reset portal or contact the IT Help Desk."
          },
          {
            "question": "My account is locked.",
            "answer": "Wait until the lockout period ends or ask your IT Administrator to unlock your account."
          },
          {
            "question": "I didn't receive the MFA code.",
            "answer": "Check your internet connection and verify that your registered MFA device is working correctly."
          }
        ]
      }
    ]
  }