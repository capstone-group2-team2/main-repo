      {
        "title": "Troubleshooting",
        "content": [
          "Ensure the printer is powered on.",
          "Check the network or USB connection.",
          "Clear the print queue.",
          "Remove any paper jam.",
          "Restart the printer.",
          "Update or reinstall the printer driver.",
          "Restart your computer.",
          "Contact IT Support if the issue persists."
        ]
      },
      {
        "title": "Best Practices",
        "content": [
          "Keep printer drivers updated.",
          "Use genuine ink or toner.",
          "Avoid overloading paper trays.",
          "Restart printers periodically.",
          "Report recurring printer errors."
        ]
      },
      {
        "title": "FAQ",
        "content": [
          {
            "question": "Why is my printer offline?",
            "answer": "Check the network connection and restart the printer."
          },
          {
            "question": "My print jobs are stuck.",
            "answer": "Clear the print queue and restart the Print Spooler service."
          },
          {
            "question": "The printer prints blank pages.",
            "answer": "Check ink or toner levels and verify the printer driver."
          }
        ]
